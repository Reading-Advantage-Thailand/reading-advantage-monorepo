{
  "name": "@reading-advantage/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cn.ts src/hooks/index.ts --format esm --dts",
    "dev": "tsup src/index.ts src/cn.ts src/hooks/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@reading-advantage/config": "workspace:*",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.1.2",
    "jsdom": "^26.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
