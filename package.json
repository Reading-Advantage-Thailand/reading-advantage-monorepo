{
  "name": "reading-advantage-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.8",
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose up -d && turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "config-drift": "pnpm --filter @reading-advantage/config test",
    "validate": "pnpm config-drift && turbo run lint test build"
  },
  "devDependencies": {
    "drizzle-orm": "0.44.7",
    "prettier": "^3.5.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.44.7",
      "next": "16.0.0",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@prisma/client",
        "prisma"
      ],
      "allowAny": [
        "@prisma/client",
        "prisma"
      ]
    },
    "resolvePeersFromWorkspaceRoot": true
  }
}
