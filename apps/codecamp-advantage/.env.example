# Database
# - DATABASE_URL: pooled (transaction-mode PgBouncer). App queries use this.
#   postgres-js is configured with prepare:false + small per-process pool;
#   see packages/db/src/connection-options.ts.
# - DIRECT_DATABASE_URL: direct (session-mode) connection. Used by
#   drizzle-kit migrations, seeds, and any LISTEN/NOTIFY consumer.
#   Required because transaction-mode pooling breaks advisory locks,
#   multi-statement DDL, and session-scoped features.
DATABASE_URL="postgresql://postgres:postgres@localhost:6432/codecamp_advantage"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codecamp_advantage"

# Optional tuning for per-process pool size (default 3). Positive integer.
# DATABASE_POOL_MAX="3"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Auth
AUTH_SECRET=""

# AI Providers
GOOGLE_AI_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""

# GitHub App (for PR review webhooks)
GITHUB_APP_ID=""
GITHUB_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
GITHUB_INSTALLATION_ID=""
