# Database
# - DATABASE_URL: pooled (transaction-mode PgBouncer). App queries use this.
# - DIRECT_DATABASE_URL: direct (session-mode) connection. Used by
#   drizzle-kit migrations, seeds, and LISTEN/NOTIFY consumers.
# See packages/db/src/connection-options.ts for the rationale.
DATABASE_URL="postgresql://postgres:postgres@localhost:6432/science_advantage?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/science_advantage?schema=public"

# Optional tuning for per-process pool size (default 3). Positive integer.
# DATABASE_POOL_MAX="3"

# Redis (for caching)
REDIS_URL="redis://localhost:6379"

# OpenAI (for AI features)
OPENAI_API_KEY="your-openai-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# AI Recommendation Service
AI_RECOMMENDER_MODEL="gpt-5-mini"
AI_RECOMMENDER_MODEL_SECONDARY="gemini-2.5-flash"
AI_RECOMMENDER_TIMEOUT_MS="10000"
# Optional legacy key supported for compatibility:
# AI_RECOMMENDATION_TIMEOUT_MS="10000"
AI_RECOMMENDER_CACHE_TTL_SECONDS="900"
AI_RECOMMENDER_HASH_SECRET="replace-me"
AI_RECOMMENDER_MAX_REQUESTS_PER_MIN="3"

# AI Image Generation
AI_IMAGE_PRIMARY_MODEL="google/gemini-3-pro-image"
# Comma-separated list, e.g. "openai/dall-e-3"
AI_IMAGE_FALLBACK_MODELS="openai/dall-e-3"
# Optional tuning
# AI_IMAGE_MAX_WIDTH="1600"
# AI_IMAGE_MAX_BYTES="200000"

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"
GOOGLE_CLOUD_STORAGE_BUCKET="your-storage-bucket"
GOOGLE_CLOUD_KEY_FILE="path/to/service-account-key.json"

# Redis (for caching)
REDIS_URL="redis://localhost:6379"

# Development
NODE_ENV="development"
DEV_AUTH_ENABLED="true"
NEXT_PUBLIC_FEATURE_AI_RECOMMENDATION="true"
NEXT_PUBLIC_STRUCTURED_CONTENT_ENABLED="true"
