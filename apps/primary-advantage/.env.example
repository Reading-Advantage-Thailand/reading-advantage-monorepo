# Database
# - DATABASE_URL: pooled (transaction-mode PgBouncer). App queries use this.
# - DIRECT_DATABASE_URL: direct (session-mode) connection. Used by
#   drizzle-kit migrations, seeds, and LISTEN/NOTIFY consumers.
# See packages/db/src/connection-options.ts for the rationale.
DATABASE_URL="postgresql://postgres:postgres@localhost:6432/primary_advantage?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/primary_advantage?schema=public"

# Optional tuning for per-process pool size (default 3). Positive integer.
# DATABASE_POOL_MAX="3"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Auth (to be configured when migrating to tRPC backend)
# AUTH_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# AI Providers
# GOOGLE_AI_API_KEY=""
# OPENAI_API_KEY=""
